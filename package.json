{
  "name": "tinkerchess",
  "version": "0.7.0",
  "private": true,
  "description": "TinkerChess — a moddable fog-of-war chess variant (phasing mechanic; checkmate rules).",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p convex && tsc --noEmit -p e2e",
    "e2e": "playwright test --config e2e/playwright.config.ts",
    "e2e:install": "playwright install chromium",
    "experiment:gr": "tsx experiments/gr.ts",
    "experiment:endgame": "tsx experiments/endgame.ts",
    "experiment:stockfish": "tsx experiments/stockfish-match.ts"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "convex-test": "^0.0.53",
    "stockfish": "^18.0.8",
    "tsx": "^4.20.6",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "convex": "^1.41.0",
    "next": "^16.2.9",
    "react": "^18.3.1",
    "react-chessboard": "^4.7.3",
    "react-dom": "^18.3.1"
  }
}
